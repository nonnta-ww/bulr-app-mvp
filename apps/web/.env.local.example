# =============================================================================
# このファイルは雛形。`cp apps/web/.env.local.example apps/web/.env.local` で
# コピーして値を埋める。.env.local は .gitignore で除外される
# =============================================================================

# -----------------------------------------------------------------------------
# 共通
# -----------------------------------------------------------------------------

# Neon Postgres 接続文字列（pooled connection 推奨）
# Neon dev branch の URL を入れる、production branch の URL は絶対にローカルに入れない
# 公開可否: サーバー専用
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth 暗号化キー（最低 32 バイトのランダム値）
# 生成例: openssl rand -base64 32
# 公開可否: サーバー専用
BETTER_AUTH_SECRET=your-32-byte-base64-secret-here

# Better Auth コールバック URL（認証フローのベース URL）
# ローカルではこれで OK、Vercel では各環境のドメインに合わせる
# 公開可否: サーバー専用
BETTER_AUTH_URL=http://localhost:3000

# Resend Magic Link 配信用 API キー
# 公開可否: サーバー専用
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# アプリのベース URL（クライアントからも参照される唯一の公開変数）
# ローカルではこれで OK、Vercel では各環境のドメインに合わせる
# 公開可否: クライアント露出可（NEXT_PUBLIC_ プレフィックスにより公開）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------

# Anthropic Claude API キー（Claude Sonnet 4.6 利用）
# 公開可否: サーバー専用
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenAI Whisper API キー（whisper-1 モデル利用）
# 公開可否: サーバー専用
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Groq API キー（Whisper large-v3-turbo モデル利用、最速プロバイダ）
# 取得: https://console.groq.com/keys
# 公開可否: サーバー専用
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Whisper プロバイダ（local-docker | openai | groq）
# ローカル開発では local-docker 推奨（コスト 0、5-15s/30s音声）
# 動作確認用には groq 推奨（最速 0.2-0.5s、$0.04/時）
# 公開可否: サーバー専用
WHISPER_PROVIDER=local-docker

# -----------------------------------------------------------------------------
# ストレージ
# -----------------------------------------------------------------------------

# Vercel Blob 読み書きトークン（bulr-audio ストア）
# 公開可否: サーバー専用
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------

# Vercel Cron 認証シークレット（Authorization: Bearer ヘッダで送信）
# 生成例: openssl rand -base64 32（最低 32 バイト）
# 公開可否: サーバー専用
CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# 管理画面
# -----------------------------------------------------------------------------

# 管理者として許可するメールアドレス（カンマ区切り CSV）
# 公開可否: サーバー専用
ADMIN_ALLOWED_EMAILS=admin@example.com,owner@example.com

# 管理画面 Basic 認証ユーザー名
# 公開可否: サーバー専用
ADMIN_BASIC_AUTH_USER=admin

# 管理画面 Basic 認証パスワード
# 公開可否: サーバー専用
ADMIN_BASIC_AUTH_PASSWORD=your-basic-auth-password-here
