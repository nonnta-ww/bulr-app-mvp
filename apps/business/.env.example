# =============================================================================
# Vercel 登録用リファレンス + ローカル開発テンプレート: bulr-mvp-business
#
# このファイルは business アプリ用の環境変数を列挙する：
#   - Vercel UI (Settings → Environment Variables) で Production / Preview 別に登録
#   - ローカルは `cp apps/business/.env.example apps/business/.env.local` でコピーし、
#     実値を埋める（3 アプリそれぞれが独立した .env.local を持つ構成）
#
# 値はプレースホルダ。実値はコミットしないこと（.env*.local は .gitignore 対象）。
#
# 詳細:
#   - 全体マスタ: /.env.example
#   - 設計: .kiro/specs/multi-app-deployment/design.md「VercelEnvVars」表
# =============================================================================

# -----------------------------------------------------------------------------
# 共有 env (3 プロジェクトすべてに同じ値を登録、Production / Preview 両方)
# -----------------------------------------------------------------------------

# Neon Postgres 接続文字列 (pooled connection)
# Production = production branch URL / Preview = dev branch URL
DATABASE_URL=postgresql://user:password@host-pooler/dbname?sslmode=require

# Better Auth 暗号化キー (3 プロジェクト同一値、最低 32 バイト base64 ランダム)
BETTER_AUTH_SECRET=your-32-byte-base64-secret-here

# Anthropic Claude API キー (business の LLM 関数 5 つが利用)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Resend Magic Link 配信用 API キー
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# メール送信元アドレス（Resend で検証済みドメイン）
# 未設定時は `onboarding@resend.dev` にフォールバック（テスト送信のみ可能）
EMAIL_FROM_ADDRESS=bulr <noreply@bulr.net>

# -----------------------------------------------------------------------------
# Business-specific env (このプロジェクトのみ)
# -----------------------------------------------------------------------------

# Better Auth コールバック URL
# Production のみ登録。Preview は packages/auth/src/server.ts の resolveBaseUrl() が
# VERCEL_URL から動的解決するため未登録で OK。
BETTER_AUTH_URL=https://bz.bulr.net

# アプリのベース URL (クライアント側に露出される唯一の公開変数)
# Production のみ登録。Preview は VERCEL_URL フォールバック。
NEXT_PUBLIC_APP_URL=https://bz.bulr.net

# 音声ストレージプロバイダ (Production / Preview 両方)
# 本番は vercel-blob 固定 (ローカル用 local-fs は本番不可)
BLOB_STORAGE_PROVIDER=vercel-blob

# -----------------------------------------------------------------------------
# Vercel が自動付与する env (手動入力不要、参考までに掲載)
# -----------------------------------------------------------------------------

# Vercel Blob 読み書きトークン
# Settings → Storage で Blob ストアを接続したとき Vercel が自動 inject (本 spec task 5.1)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Vercel Cron 認証シークレット
# apps/business/vercel.json の crons 定義により、Cron Jobs 登録時に Vercel が自動 inject
# CRON_SECRET=auto-injected-by-vercel

# -----------------------------------------------------------------------------
# 面接キャプチャ（Recall）— このプロジェクトのみ
# -----------------------------------------------------------------------------

# Recall.ai API キー（ボット参加・退出・録音取得に使用）
# 取得: https://www.recall.ai/ → Dashboard → API Keys
# Production / Preview 両方に登録
RECALL_API_KEY=your-recall-api-key-here

# Recall.ai API ベース URL（リージョン別の「ホストのみ」。末尾に /api/v1 を付けない）
# 例: https://us-west-2.recall.ai / https://us-east-1.recall.ai
# 取得: Recall ダッシュボードのリージョン設定を参照
# 注意: コード側（recall-client.ts）が /api/v1/bot/ を付与する。ここに /api/v1 を含めると
#       パスが二重化（.../api/v1/api/v1/bot/）してボット作成が 404 で失敗する
# Production / Preview 両方に登録
RECALL_API_BASE_URL=https://us-west-2.recall.ai

# Recall.ai Webhook シークレット（status イベントの Svix 署名検証用）
# 取得: Recall ダッシュボード → Webhooks → Signing Secret
# Production / Preview 両方に登録
RECALL_WEBHOOK_SECRET=your-recall-webhook-secret-here

# リアルタイム転写プロバイダ（Recall の recording_config.transcript.provider に渡す）
# 例: deepgram_streaming（既定）| assembly_ai | gladia
# Production / Preview 両方に登録
CAPTURE_TRANSCRIPT_PROVIDER=deepgram_streaming

# -----------------------------------------------------------------------------
# Whisper (本 spec では未設定、deferred)
# -----------------------------------------------------------------------------

# OpenAI API キー (Whisper API 利用)
# 本 spec の Amendment (2026-05-27) で未登録。OpenAI API キー取得後に追加登録すれば
# Whisper 文字起こしが本番動作する。
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Whisper プロバイダ (openai 固定、本番では local-docker 不可)
# OPENAI_API_KEY と同時に登録。
# WHISPER_PROVIDER=openai
