{
  "name": "bulr-app-mvp",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:clean": "node scripts/free-dev-ports.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:up": "docker compose -f docker/compose.yml up -d",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:reset": "docker compose -f docker/compose.yml down -v && docker compose -f docker/compose.yml up -d",
    "seed:patterns": "pnpm --filter @bulr/db exec tsx ../../scripts/seed-assessment-patterns.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "esbuild": ">=0.28.1",
      "react-is": "^19.0.0",
      "form-data": ">=4.0.6",
      "js-yaml": ">=4.2.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9.39",
    "prettier": "^3.8",
    "turbo": "^2.9.16",
    "typescript": "^5.4",
    "typescript-eslint": "^8.59"
  }
}
